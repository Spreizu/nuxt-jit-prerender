{
  "name": "nuxt-jit-prerender",
  "version": "0.0.1",
  "description": "REST API-based static site generation for Nuxt 4. Generate pages incrementally or fully via HTTP endpoints. Lightweight alternative to traditional SSG.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spreizu/nuxt-jit-prerender.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "postinstall": "pnpm dev:prepare",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2"
  },
  "devDependencies": {
    "@nuxt/devtools": "^4.0.0-alpha.3",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "nuxt": "^4.4.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
