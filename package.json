{
  "name": "nuxt-jit-prerender",
  "version": "0.0.2",
  "description": "REST API-based static site generation for Nuxt 4. Generate pages incrementally or fully via HTTP endpoints. Lightweight alternative to traditional SSG.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spreizu/nuxt-jit-prerender.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "dev:server": "NUXT_JIT_PRERENDER_OUTPUT_DIR=./playground/.output node playground/.output/server/index.mjs",
    "release": "pnpm lint && pnpm test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@nuxt/devtools": "^4.0.0-alpha.3",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.2",
    "changelogen": "^0.6.2",
    "nuxt": "^4.4.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
